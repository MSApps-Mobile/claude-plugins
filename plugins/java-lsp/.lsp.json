{
  "java": {
    "command": "jdtls",
    "extensionToLanguage": {
      ".java": "java"
    },
    "restartOnCrash": true,
    "maxRestarts": 3,
    "startupTimeoutMs": 45000,
    "shutdownTimeoutMs": 5000,
    "initializationOptions": {
      "bundles": [],
      "workspaceFolders": [],
      "settings": {
        "java": {
          "import": {
            "gradle": { "enabled": true },
            "maven": { "enabled": true }
          },
          "autobuild": { "enabled": true },
          "configuration": {
            "updateBuildConfiguration": "automatic"
          }
        }
      }
    }
  }
}
