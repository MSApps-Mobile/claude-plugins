{
  "mcpServers": {
    "zoho-mail": {
      "command": "node",
      "args": ["${ZOHO_MAIL_MCP_PATH}/dist/index.js"],
      "env": {
        "ZOHO_CLIENT_ID": "${ZOHO_CLIENT_ID}",
        "ZOHO_CLIENT_SECRET": "${ZOHO_CLIENT_SECRET}",
        "ZOHO_ACCOUNTS": "${ZOHO_ACCOUNTS}"
      }
    }
  }
}
