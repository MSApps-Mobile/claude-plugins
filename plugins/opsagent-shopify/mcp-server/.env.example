# opsagent-shopify-mcp — environment

# Default shop used when a tool call omits `shop` (optional in multi-tenant mode).
# Format: <store-handle>.myshopify.com
SHOPIFY_DEFAULT_SHOP=

# --- Storefront API ---
# Storefront API access token (Admin > Headless channel > Storefront API).
# Required for Storefront GraphQL tools (get_product, policies, collections).
SHOPIFY_STOREFRONT_TOKEN=

# --- Admin API ---
# Admin API access token (Settings > Apps > Develop apps > Admin API access token).
# Required for all shopify_admin_* tools (products CRUD, files, orders, customers, themes, metafields).
# Scopes needed: read_products, write_products, read_orders, read_customers,
#                 read_themes, read_files, write_files, read_content, write_content
SHOPIFY_ADMIN_TOKEN=

# API version for both Storefront and Admin.
SHOPIFY_API_VERSION=2025-04

# Optional: override the Storefront MCP endpoint path (defaults to /api/mcp).
SHOPIFY_MCP_PATH=/api/mcp
